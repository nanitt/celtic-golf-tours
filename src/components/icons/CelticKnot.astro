---
interface Props {
  class?: string;
  position?: 'top-left' | 'bottom-right';
}

const { class: className = '', position = 'top-left' } = Astro.props;

// Mirror the SVG for bottom-right position
const transform = position === 'bottom-right' ? 'scale(-1, -1)' : '';
---

<svg
  class={className}
  viewBox="0 0 100 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  style={transform ? `transform: ${transform}` : undefined}
  aria-hidden="true"
>
  <!-- Celtic Corner Knot Pattern -->
  <g stroke="currentColor" stroke-width="2" fill="none">
    <!-- Outer corner arc -->
    <path d="M 5 50 Q 5 5, 50 5" />
    <path d="M 10 50 Q 10 10, 50 10" />

    <!-- Interlocking loops - top section -->
    <path d="M 20 5 Q 20 20, 35 20 Q 50 20, 50 35" />
    <path d="M 5 20 Q 20 20, 20 35 Q 20 50, 35 50" />

    <!-- Inner interlocking - creates the "knot" illusion -->
    <path d="M 25 15 Q 35 15, 35 25 Q 35 35, 25 35 Q 15 35, 15 25 Q 15 15, 25 15" />

    <!-- Second loop layer -->
    <path d="M 30 25 Q 40 25, 40 35 Q 40 45, 30 45" />
    <path d="M 25 30 Q 25 40, 35 40 Q 45 40, 45 30" />

    <!-- Decorative spirals -->
    <path d="M 42 8 Q 48 8, 48 14 Q 48 20, 42 20" />
    <path d="M 8 42 Q 8 48, 14 48 Q 20 48, 20 42" />

    <!-- Extended corner lines -->
    <path d="M 50 2 L 50 8" />
    <path d="M 2 50 L 8 50" />

    <!-- Inner detail work -->
    <circle cx="25" cy="25" r="3" />
    <circle cx="35" cy="35" r="2" />

    <!-- Trailing decorative elements -->
    <path d="M 55 5 Q 55 12, 48 12" />
    <path d="M 5 55 Q 12 55, 12 48" />
  </g>
</svg>
