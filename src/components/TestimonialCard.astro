---
interface Props {
  quote: string;
  name: string;
  location?: string;
  tour?: string;
  image?: string;
  variant?: 'default' | 'featured';
}

const { quote, name, location, tour, image, variant = 'default' } = Astro.props;

const isFeatured = variant === 'featured';
---

<div class={`p-7 sm:p-8 ${isFeatured ? 'bg-stone' : 'bg-white'} shadow-sm border border-gray-100`}>
  <!-- Quote Icon -->
  <svg class={`mb-4 ${isFeatured ? 'w-12 h-12 text-brass/40' : 'w-10 h-10 text-brass/30'}`} fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
  </svg>

  <!-- Quote -->
  <p class={`leading-relaxed mb-6 ${isFeatured ? 'font-heading-display text-xl text-charcoal' : 'text-gray-700 italic'}`} style={isFeatured ? 'font-weight: 400;' : ''}>
    {isFeatured ? quote : `"${quote}"`}
  </p>

  <!-- Author -->
  <div class="flex items-center">
    {image ? (
      <img src={image} alt={name} class="w-12 h-12 object-cover mr-4" />
    ) : (
      <div class="w-12 h-12 bg-celtic/10 flex items-center justify-center mr-4">
        <span class="text-celtic font-semibold text-lg">{name.charAt(0)}</span>
      </div>
    )}
    <div>
      <p class="font-semibold text-celtic">{name}</p>
      {(location || tour) && (
        <p class="text-sm text-text">
          {location}{location && tour && ' · '}{tour}
        </p>
      )}
    </div>
  </div>
</div>
