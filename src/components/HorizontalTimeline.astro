---
/**
 * HorizontalTimeline - Day-in-the-Life horizontal scroll section
 * Shows a typical day on a Celtic Golf Tour
 */

import TimelineStop from './TimelineStop.astro';
import CelticDivider from './CelticDivider.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;

// Timeline data - a typical day on tour
const timelineStops = [
  {
    time: '7:30 AM',
    title: 'Wake Up at the Manor',
    description: 'Rise in your period suite overlooking rolling parkland. The morning mist begins to lift.',
    image: 'https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    icon: 'hotel' as const
  },
  {
    time: '8:30 AM',
    title: 'Full Irish Breakfast',
    description: 'Black pudding, rashers, and perfectly poached eggs. Fuel for the links ahead.',
    image: 'https://images.unsplash.com/photo-1533089860892-a7c6f0a88666?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    icon: 'coffee' as const
  },
  {
    time: '10:00 AM',
    title: 'First Tee at Lahinch',
    description: 'The famous Dell hole awaits. Watch for the goats—they\'re never wrong about the weather.',
    image: 'https://images.unsplash.com/photo-1693113448333-0123750f17f6?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    icon: 'golf' as const
  },
  {
    time: '2:30 PM',
    title: 'Lunch at the Clubhouse',
    description: 'Toasted sandwiches, soup of the day, and tales of the morning\'s adventures.',
    image: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    icon: 'dining' as const
  },
  {
    time: '4:00 PM',
    title: 'Afternoon Round',
    description: 'Back nine at Doonbeg. The Atlantic crashes against the cliffs as the wind picks up.',
    image: 'https://images.unsplash.com/photo-1693113448288-015fb6eed7c9?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    icon: 'golf' as const
  },
  {
    time: '6:30 PM',
    title: 'Sunset over the Bay',
    description: 'Golden hour on the Wild Atlantic Way. The perfect moment to reflect on the day.',
    image: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    icon: 'sunset' as const
  },
  {
    time: '8:00 PM',
    title: 'Whiskey & Fine Dining',
    description: 'A dram of 18-year Redbreast, followed by locally-caught seafood at a Michelin-starred table.',
    image: 'https://images.unsplash.com/photo-1569529465841-dfecdab7503b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    icon: 'whiskey' as const
  }
];
---

<section class:list={['horizontal-timeline-section', className]} data-horizontal-timeline>
  <!-- Header -->
  <div class="timeline-header">
    <p class="timeline-kicker">The Experience</p>
    <h2 class="timeline-title">A Day in the Life</h2>
    <CelticDivider variant="simple" color="brass" width="narrow" class="my-6" />
    <p class="timeline-subtitle">
      Every day on tour is an adventure. Here's a glimpse of what awaits.
    </p>
  </div>

  <!-- Scroll container -->
  <div class="timeline-container" data-timeline-container>
    <!-- Progress track -->
    <div class="timeline-progress" aria-hidden="true">
      <div class="progress-track">
        <div class="progress-fill" data-timeline-progress></div>
      </div>
    </div>

    <!-- Timeline track -->
    <div class="timeline-track" data-timeline-track>
      {timelineStops.map((stop, index) => (
        <TimelineStop
          time={stop.time}
          title={stop.title}
          description={stop.description}
          image={stop.image}
          icon={stop.icon}
          isFirst={index === 0}
          isLast={index === timelineStops.length - 1}
        />
      ))}
    </div>

    <!-- Navigation arrows (desktop) -->
    <button class="timeline-nav timeline-nav-prev" aria-label="Previous" data-timeline-prev>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>
    <button class="timeline-nav timeline-nav-next" aria-label="Next" data-timeline-next>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>

  <!-- Scroll hint (mobile) -->
  <div class="scroll-hint" aria-hidden="true">
    <span>Swipe to explore</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </div>
</section>

<style>
  .horizontal-timeline-section {
    position: relative;
    padding: 5rem 0;
    background: linear-gradient(to bottom, var(--color-stone), var(--color-cream));
    overflow: hidden;
  }

  /* Header */
  .timeline-header {
    text-align: center;
    padding: 0 1.5rem 3rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .timeline-kicker {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-celtic);
    margin-bottom: 0.75rem;
  }

  .timeline-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-charcoal);
    margin-bottom: 0.5rem;
  }

  .timeline-subtitle {
    font-size: 1rem;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  /* Container */
  .timeline-container {
    position: relative;
    padding: 2rem 0;
  }

  /* Progress track */
  .timeline-progress {
    position: absolute;
    top: 2.75rem;
    left: 5%;
    right: 5%;
    z-index: 1;
  }

  .progress-track {
    height: 2px;
    background: rgba(139, 115, 85, 0.2);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-brass);
    width: calc(var(--scroll-progress, 0) * 100%);
    transition: width 0.1s ease-out;
  }

  /* Timeline track */
  .timeline-track {
    display: flex;
    gap: 0;
    padding: 2rem 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  .timeline-track::-webkit-scrollbar {
    display: none;
  }

  /* Navigation */
  .timeline-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: white;
    border: 1px solid var(--color-stone-dark);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
    z-index: 10;
  }

  .timeline-nav:hover {
    background: var(--color-celtic);
    border-color: var(--color-celtic);
    color: white;
  }

  .timeline-nav:focus-visible {
    outline: 2px solid var(--color-celtic);
    outline-offset: 3px;
  }

  .timeline-nav-prev {
    left: 1rem;
  }

  .timeline-nav-next {
    right: 1rem;
  }

  .timeline-nav svg {
    color: inherit;
  }

  /* Scroll hint */
  .scroll-hint {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    font-size: 0.75rem;
    color: var(--color-charcoal);
    opacity: 0.6;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .timeline-nav {
      display: none;
    }

    .scroll-hint {
      display: flex;
    }

    .timeline-progress {
      display: none;
    }
  }

  /* Large screens */
  @media (min-width: 1200px) {
    .timeline-nav-prev {
      left: 2rem;
    }

    .timeline-nav-next {
      right: 2rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .timeline-track {
      scroll-behavior: auto;
    }

    .progress-fill {
      transition: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('[data-horizontal-timeline]');
    const track = document.querySelector('[data-timeline-track]') as HTMLElement;
    const prevBtn = document.querySelector('[data-timeline-prev]');
    const nextBtn = document.querySelector('[data-timeline-next]');
    const progressFill = document.querySelector('[data-timeline-progress]') as HTMLElement;

    if (!track) return;

    // Calculate scroll amount (one card width)
    const getScrollAmount = () => {
      const firstCard = track.querySelector('.timeline-stop');
      return firstCard ? firstCard.clientWidth : 320;
    };

    // Update progress bar
    const updateProgress = () => {
      if (!progressFill) return;

      const scrollLeft = track.scrollLeft;
      const maxScroll = track.scrollWidth - track.clientWidth;
      const progress = maxScroll > 0 ? scrollLeft / maxScroll : 0;

      progressFill.style.setProperty('--scroll-progress', progress.toString());
    };

    // Navigation handlers
    prevBtn?.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn?.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    // Track scroll for progress
    track.addEventListener('scroll', updateProgress, { passive: true });

    // Initial progress update
    updateProgress();

    // Keyboard navigation when focused
    track.setAttribute('tabindex', '0');
    track.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      }
    });
  });
</script>
