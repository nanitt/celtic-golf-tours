---
/**
 * CelticDivider - Ornamental divider with Celtic-inspired design
 *
 * Variants:
 * - simple: Gold line with diamond center
 * - knot: Celtic knot pattern
 * - wave: Flowing wave pattern
 * - ornate: Full ornamental design
 */

interface Props {
  variant?: 'simple' | 'knot' | 'wave' | 'ornate';
  color?: 'brass' | 'celtic' | 'white' | 'charcoal';
  width?: 'narrow' | 'medium' | 'wide';
  class?: string;
}

const {
  variant = 'simple',
  color = 'brass',
  width = 'medium',
  class: className = ''
} = Astro.props;

const colorClasses: Record<string, string> = {
  brass: 'text-brass',
  celtic: 'text-celtic',
  white: 'text-white',
  charcoal: 'text-charcoal'
};

const widthClasses: Record<string, string> = {
  narrow: 'max-w-[120px]',
  medium: 'max-w-[200px]',
  wide: 'max-w-[300px]'
};
---

<div
  class:list={[
    'celtic-divider flex items-center justify-center gap-3 mx-auto my-8',
    widthClasses[width],
    colorClasses[color],
    className
  ]}
  role="presentation"
  aria-hidden="true"
>
  {variant === 'simple' && (
    <>
      <div class="flex-1 h-px bg-gradient-to-r from-transparent to-current"></div>
      <div class="w-2 h-2 bg-current rotate-45"></div>
      <div class="flex-1 h-px bg-gradient-to-l from-transparent to-current"></div>
    </>
  )}

  {variant === 'knot' && (
    <>
      <div class="flex-1 h-px bg-gradient-to-r from-transparent to-current"></div>
      <svg class="w-8 h-8" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
        <!-- Simple Celtic knot pattern -->
        <circle cx="16" cy="16" r="6" />
        <path d="M10 16c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke-linecap="round" />
        <path d="M16 10c3.3 0 6 2.7 6 6s-2.7 6-6 6" stroke-linecap="round" />
        <path d="M22 16c0 3.3-2.7 6-6 6s-6-2.7-6-6" stroke-linecap="round" />
        <path d="M16 22c-3.3 0-6-2.7-6-6s2.7-6 6-6" stroke-linecap="round" />
      </svg>
      <div class="flex-1 h-px bg-gradient-to-l from-transparent to-current"></div>
    </>
  )}

  {variant === 'wave' && (
    <>
      <svg class="w-full h-4" viewBox="0 0 200 16" fill="none" stroke="currentColor" stroke-width="1" preserveAspectRatio="none">
        <path d="M0 8 Q25 2, 50 8 T100 8 T150 8 T200 8" stroke-linecap="round" />
      </svg>
    </>
  )}

  {variant === 'ornate' && (
    <>
      <svg class="w-full h-6" viewBox="0 0 200 24" fill="none" preserveAspectRatio="xMidYMid meet">
        <!-- Left flourish -->
        <path
          d="M0 12 Q20 12, 30 8 Q40 4, 50 8 Q55 10, 60 12"
          stroke="currentColor"
          stroke-width="1"
          fill="none"
        />
        <!-- Left dot -->
        <circle cx="70" cy="12" r="2" fill="currentColor" />

        <!-- Center diamond -->
        <rect x="96" y="8" width="8" height="8" transform="rotate(45 100 12)" fill="currentColor" />

        <!-- Right dot -->
        <circle cx="130" cy="12" r="2" fill="currentColor" />
        <!-- Right flourish -->
        <path
          d="M200 12 Q180 12, 170 8 Q160 4, 150 8 Q145 10, 140 12"
          stroke="currentColor"
          stroke-width="1"
          fill="none"
        />
      </svg>
    </>
  )}
</div>

<style>
  .celtic-divider svg {
    opacity: 0.9;
  }

  /* Subtle animation on knot variant */
  .celtic-divider svg circle,
  .celtic-divider svg path {
    transition: opacity 0.3s ease;
  }

  @media (prefers-reduced-motion: no-preference) {
    .celtic-divider:hover svg {
      opacity: 1;
    }
  }
</style>
