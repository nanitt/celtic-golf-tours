---
interface Props {
  quote: string;
  name: string;
  location?: string;
  image?: string;
  trip?: string;
}

const { quote, name, location, image, trip } = Astro.props;
---

<div class="max-w-4xl mx-auto text-center">
  <!-- Quote Mark -->
  <div class="mb-8" data-reveal="fade-up">
    <svg class="w-12 h-12 text-charcoal/20 mx-auto" fill="currentColor" viewBox="0 0 24 24">
      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
    </svg>
  </div>

  <!-- Quote -->
  <blockquote class="font-heading text-2xl md:text-3xl lg:text-4xl text-charcoal leading-relaxed mb-10" data-reveal="fade-up" data-reveal-delay="1">
    "{quote}"
  </blockquote>

  <!-- Attribution -->
  <div class="flex flex-col items-center" data-reveal="fade-up" data-reveal-delay="2">
    {image && (
      <img
        src={image}
        alt={name}
        class="w-16 h-16 rounded-full object-cover mb-4"
      />
    )}
    <cite class="not-italic">
      <span class="block text-charcoal font-medium text-lg">{name}</span>
      {location && (
        <span class="block text-text-muted text-sm mt-1">{location}</span>
      )}
      {trip && (
        <span class="block text-brass text-sm mt-2">{trip}</span>
      )}
    </cite>
  </div>
</div>
