---
import '../styles/global.css';

const error = Astro.url.searchParams.get('error');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Login to Celtic Golf Tours" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>Login | Celtic Golf Tours</title>
  </head>
  <body class="min-h-screen flex items-center justify-center bg-stone">
    <div class="w-full max-w-md px-6">
      <div class="bg-white p-8 shadow-sm">
        <div class="text-center mb-8">
          <h1 class="font-heading text-3xl text-charcoal mb-2">Celtic Golf Tours</h1>
          <p class="text-text text-sm">Enter password to access the site</p>
        </div>

        {error === 'invalid' && (
          <div class="mb-6 p-3 bg-red-50 border border-red-200 text-red-700 text-sm text-center">
            Incorrect password. Please try again.
          </div>
        )}

        <form action="/api/auth/login" method="POST" class="space-y-6">
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              autofocus
              class="w-full px-4 py-3 border border-gray-300 focus:border-charcoal focus:outline-none transition-colors"
              placeholder="Enter site password"
            />
          </div>

          <button
            type="submit"
            class="w-full bg-charcoal text-white py-3 px-4 font-medium hover:bg-charcoal-light transition-colors"
          >
            Enter Site
          </button>
        </form>
      </div>
    </div>
  </body>
</html>
