---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import HeritageWall from '../components/HeritageWall.astro';
import CelticDivider from '../components/CelticDivider.astro';
import TexturedSection from '../components/TexturedSection.astro';
---

<Layout title="About Us" description="Learn about Celtic Golf Tours - luxury golf travel experts creating unforgettable experiences across Scotland, Ireland, Wales, and England.">
  <Hero
    title="About Celtic Golf Tours"
    subtitle="Passionate golfers creating extraordinary experiences"
    backgroundImage="https://images.unsplash.com/photo-1743185836009-848e5035422b?ixlib=rb-4.0.3&auto=format&fit=crop&w=1800&q=80"
    size="large"
    ctaText=""
  />

  <!-- Our Story Section -->
  <section class="section-padding bg-white">
    <div class="content-wide px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div>
          <p class="section-kicker mb-4">Our Story</p>
          <h2 class="font-heading text-section mb-8" style="font-size: clamp(2rem, 4vw, var(--text-section));">Born From a Love of the Game</h2>
          <p class="text-text leading-relaxed mb-6">
            Celtic Golf Tours was born from a simple belief: that golf travel should be extraordinary.
            As a proud part of the Celtic Golf Centre family, we bring decades of golfing expertise
            and a genuine passion for the game to every tour we create.
          </p>

          <!-- Pulled blockquote -->
          <blockquote class="border-l-4 border-brass pl-6 my-8">
            <p class="font-heading-display text-2xl text-charcoal leading-snug" style="font-weight: 400;">
              Your perfect trip is our personal mission.
            </p>
          </blockquote>

          <p class="text-text leading-relaxed mb-6">
            We've walked the fairways, tested the greens, and experienced the hospitality across
            Scotland, Ireland, Wales, and England. This first-hand knowledge, combined with our
            industry relationships, allows us to craft tours that go beyond the ordinary.
          </p>
          <p class="text-text leading-relaxed">
            Whether you're playing your first links course or ticking off your bucket list,
            we're here to make it unforgettable.
          </p>
        </div>
        <div class="group relative aspect-[4/3] overflow-hidden">
          <div
            class="absolute inset-0 bg-cover bg-center scale-on-hover"
            style="background-image: url('https://images.unsplash.com/photo-1725835567442-7f39d9199f8c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80')"
          ></div>
          <div class="absolute inset-0 overlay-default overlay-hover transition-premium"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section — Asymmetric Editorial -->
  <TexturedSection texture="pressed-paper" background="stone">
    <div class="content-wide px-6 lg:px-12">
      <div class="space-y-20 lg:space-y-28">
        <!-- Differentiator 1 -->
        <div data-reveal="fade-up">
          <p class="section-kicker mb-4">What Sets Us Apart</p>
          <h3 class="font-heading-display text-3xl lg:text-4xl text-charcoal mb-6 max-w-2xl" style="font-weight: 300;">Every course we recommend, we've played.</h3>
          <p class="text-text leading-relaxed max-w-xl">
            If we haven't walked the fairways ourselves, it doesn't go on an itinerary. No exceptions. We'd rather tell you a course isn't right for your trip than send you somewhere we haven't personally vetted.
          </p>
        </div>

        <!-- Differentiator 2 -->
        <div class="max-w-lg ml-auto" data-reveal="fade-up">
          <div class="w-16 h-px bg-brass mb-6"></div>
          <h3 class="font-heading text-2xl lg:text-3xl text-charcoal mb-6">We know the people who run the courses.</h3>
          <p class="text-text leading-relaxed">
            Our relationships with starters, head pros, and club secretaries across the British Isles aren't just useful. They're the reason you can play courses others can't book — and why your trip runs without a single hitch.
          </p>
        </div>

        <!-- Differentiator 3 -->
        <div data-reveal="fade-up">
          <div class="flex items-center gap-4 mb-6">
            <span class="w-2.5 h-2.5 bg-brass rotate-45 flex-shrink-0"></span>
            <div class="w-12 h-px bg-brass/50"></div>
          </div>
          <h3 class="font-heading text-2xl lg:text-3xl text-charcoal mb-6">Deliberately small. Always.</h3>
          <p class="text-text leading-relaxed max-w-xl">
            We cap every group at twelve. Not because of logistics — because small groups play better golf and have better trips. Your experience will never be sacrificed to fill a coach.
          </p>
        </div>
      </div>
    </div>
  </TexturedSection>

  <!-- By the Numbers -->
  <section class="py-16 bg-charcoal">
    <div class="content-wide px-6 lg:px-12">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        <div data-reveal="fade-up" data-reveal-delay="1">
          <p class="font-heading-display text-4xl lg:text-5xl text-champagne" style="font-weight: 300;">500+</p>
          <p class="section-kicker-light mt-2">Happy Golfers</p>
        </div>
        <div data-reveal="fade-up" data-reveal-delay="2">
          <p class="font-heading-display text-4xl lg:text-5xl text-brass" style="font-weight: 300;">4.9</p>
          <p class="section-kicker-light mt-2">Average Rating</p>
        </div>
        <div data-reveal="fade-up" data-reveal-delay="3">
          <p class="font-heading-display text-4xl lg:text-5xl text-champagne" style="font-weight: 300;">150+</p>
          <p class="section-kicker-light mt-2">Tours Delivered</p>
        </div>
        <div data-reveal="fade-up" data-reveal-delay="4">
          <p class="font-heading-display text-4xl lg:text-5xl text-champagne" style="font-weight: 300;">20+</p>
          <p class="section-kicker-light mt-2">Years' Experience</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Heritage Wall -->
  <HeritageWall />

  <!-- Celtic Golf Centre Connection -->
  <section class="section-padding bg-white">
    <div class="content-wide px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
        <div class="lg:order-2">
          <p class="section-kicker mb-4">Our Heritage</p>
          <h2 class="font-heading text-section mb-4" style="font-size: clamp(2rem, 4vw, var(--text-section));">Part of the Celtic Golf Family</h2>
          <!-- Brass diamond divider -->
          <div class="flex items-center gap-3 mb-8">
            <div class="w-12 h-0.5 bg-brass"></div>
            <div class="w-1.5 h-1.5 bg-brass rotate-45"></div>
          </div>
          <p class="text-text leading-relaxed mb-6">
            Celtic Golf Tours is a proud part of Celtic Golf Centre, bringing
            together our extensive golfing expertise with a passion for travel.
          </p>
          <p class="text-text leading-relaxed mb-6">
            This connection means we have deep roots in the golf industry, established
            relationships with courses across the British Isles, and the experience
            to deliver exceptional tours every time.
          </p>
          <p class="text-text leading-relaxed">
            When you book with Celtic Golf Tours, you're not just getting a travel agent—
            you're getting a team of golf professionals dedicated to your perfect trip.
          </p>
        </div>
        <div class="lg:order-1 group relative aspect-[4/3] overflow-hidden">
          <div
            class="absolute inset-0 bg-cover bg-center scale-on-hover"
            style="background-image: url('https://images.unsplash.com/photo-1674884070794-b61d85f9adf8?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80')"
          ></div>
          <div class="absolute inset-0 overlay-default overlay-hover transition-premium"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-charcoal">
    <div class="content-narrow px-6 lg:px-12 text-center">
      <h2 class="font-heading text-3xl md:text-4xl text-white mb-6">
        Let's Plan Your Adventure
      </h2>
      <p class="text-white/70 text-lg mb-10 max-w-xl mx-auto">
        Ready to experience golf the way it should be? Get in touch and let's start planning.
      </p>
      <a
        href="/contact"
        class="btn-primary btn-lg btn-primary-inverted"
      >
        Contact Us
        <svg class="arrow w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
