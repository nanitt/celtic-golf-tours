---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import HostedExperienceCard from '../components/HostedExperienceCard.astro';
import { getAllExperiences, getUpcomingExperiences } from '../data/sanity-experiences';

const experienceTypes = [
  {
    title: 'Custom Tours',
    description: 'Your vision, our expertise. We craft fully bespoke golf tours tailored to your exact preferences, handicap level, and travel style. From course selection to accommodation, every detail is personalised.',
    features: [
      'Personalised itinerary design',
      'Choice of any courses and destinations',
      'Flexible dates and group sizes',
      'Accommodation to suit your style',
      'Private transfers throughout',
      'Dedicated tour coordinator'
    ],
    image: 'https://images.unsplash.com/photo-1685880841774-d3cd18c3207a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
  },
  {
    title: 'Small Group Tours',
    description: 'Join fellow golf enthusiasts on expertly curated trips to the world\'s greatest courses. Our small group tours offer the perfect blend of camaraderie, expert guidance, and exceptional golf.',
    features: [
      'Maximum 12 golfers per tour',
      'Expert tour host throughout',
      'Pre-planned premium itineraries',
      'All-inclusive pricing',
      'Meet like-minded golfers',
      'Best value for money'
    ],
    image: 'https://images.unsplash.com/photo-1694636507260-8b2428e3b738?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
  },
  {
    title: 'Corporate Events',
    description: 'Impress clients, reward teams, and build relationships through unforgettable golf experiences. We handle every detail so you can focus on your guests.',
    features: [
      'Client entertainment packages',
      'Team building golf days',
      'Tournament organisation',
      'Branded experiences available',
      'Full event management',
      'Flexible budgets and formats'
    ],
    image: 'https://images.unsplash.com/photo-1635328800844-0e68e80ab258?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80'
  }
];

const inclusions = [
  { title: 'Premium Accommodation', description: 'Carefully selected hotels and resorts' },
  { title: 'Guaranteed Tee Times', description: 'Priority access at top courses' },
  { title: 'All Transfers', description: 'Airport pickups and transport throughout' },
  { title: '24/7 Support', description: 'Dedicated assistance before, during, and after' }
];

const hostedExperiences = await getAllExperiences();
const upcomingExperiences = await getUpcomingExperiences();

const faqs = [
  {
    q: "What's included in a hosted experience?",
    a: "All hosted experiences include premium accommodation, guaranteed tee times at every course on the itinerary, private transfers throughout, an expert Celtic Golf Tours host for the duration, and 24/7 support. Flights are not included."
  },
  {
    q: "How far ahead should I book?",
    a: "For hosted experiences, we recommend booking 6–12 months in advance. Popular departures — particularly anything touching St Andrews or Royal Portrush — often fill six months out. For custom tours, 3–6 months typically works, though peak summer dates fill quickly."
  },
  {
    q: "What's the typical group size?",
    a: "Hosted experiences run with a maximum of 12 golfers — deliberately small, so your experience is personal rather than a package tour. Custom groups can be as small as 2 or as large as 12."
  },
  {
    q: "Do I need to be a low handicap to join?",
    a: "Not at all. Our hosted experiences welcome golfers of all abilities. Some courses require a handicap certificate for booking purposes — we'll let you know which ones apply to your itinerary and help you arrange documentation."
  },
  {
    q: "What standard of accommodation can I expect?",
    a: "We work exclusively with hotels and properties that we've personally stayed in and assessed. Expect 4 and 5-star properties, often within walking distance of the courses you're playing."
  },
  {
    q: "Can I customise a hosted experience?",
    a: "Hosted experiences have a set itinerary and departure date. If you'd like a fully bespoke trip — your courses, your dates, your pace — a Custom Tour is what you're after. Get in touch and we'll build it from scratch."
  },
  {
    q: "What is your cancellation policy?",
    a: "Each experience has specific terms detailed in your booking confirmation. In general, deposits are non-refundable but full payments are transferable to a future departure in most cases. We'll walk you through everything before you commit."
  }
];
---

<Layout title="Experiences" description="Discover our range of luxury golf experiences - from bespoke custom tours to hosted trips and corporate events.">
  <Hero
    title="Extraordinary Golf Experiences"
    subtitle="From intimate custom tours to our signature hosted journeys, discover the perfect way to experience the world's finest courses"
    backgroundImage="https://images.unsplash.com/photo-1683169285928-eb93b0169793?ixlib=rb-4.0.3&auto=format&fit=crop&w=1800&q=80"
    size="large"
    ctaText=""
  />

  <!-- Hosted Experiences Section (Featured) -->
  <section class="section-padding bg-white">
    <div class="content-wide px-6 lg:px-12">
      <div class="text-center mb-16">
        <p class="section-kicker mb-4">Limited Availability</p>
        <h2 class="font-heading text-section mb-4" style="font-size: clamp(2rem, 4vw, var(--text-section));">Hosted Experiences</h2>
        <p class="text-text max-w-2xl mx-auto">
          Our signature bucket-list trips led by the Celtic Golf Tours team. Carefully crafted journeys to extraordinary destinations with exclusive access and unforgettable moments.
        </p>
      </div>

      <div class="space-y-8">
        {hostedExperiences.map((experience, index) => (
          <HostedExperienceCard experience={experience} featured={index === 0} />
        ))}
      </div>
    </div>
  </section>

  <!-- Experience Types Section -->
  <section class="section-padding bg-stone">
    <div class="content-wide px-6 lg:px-12">
      <div class="text-center mb-16">
        <h2 class="font-heading text-section mb-4" style="font-size: clamp(2rem, 4vw, var(--text-section));">Ways to Travel</h2>
        <p class="text-text max-w-2xl mx-auto">
          Choose from our range of expertly crafted tour options
        </p>
      </div>

      <div class="space-y-32">
        {experienceTypes.map((exp, index) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center`}>
            <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
              <h3 class="font-heading text-3xl md:text-4xl mb-6">
                {exp.title}
              </h3>
              <p class="text-text leading-relaxed mb-8">
                {exp.description}
              </p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
                {exp.features.map((feature) => (
                  <li class="flex items-center text-sm text-text">
                    <svg class="w-4 h-4 text-celtic mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
              <a
                href="/contact"
                class="btn-primary btn-md"
              >
                Enquire About {exp.title}
              </a>
            </div>
            <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
              <div class="group relative aspect-[4/3] overflow-hidden">
                <div
                  class="absolute inset-0 bg-cover bg-center scale-on-hover"
                  style={`background-image: url('${exp.image}')`}
                ></div>
                <div class="absolute inset-0 overlay-default overlay-hover transition-premium"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included Section -->
  <section class="section-padding bg-white">
    <div class="content-narrow px-6 lg:px-12">
      <div class="text-center mb-16">
        <h2 class="font-heading text-section mb-4" style="font-size: clamp(2rem, 4vw, var(--text-section));">What's Included</h2>
        <p class="text-text max-w-xl mx-auto">
          Every Celtic Golf Tours experience includes these essentials as standard
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        {inclusions.map((item) => (
          <div class="text-center">
            <h3 class="font-heading text-xl mb-3">{item.title}</h3>
            <p class="text-text text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section-padding bg-cream">
    <div class="content-narrow px-6 lg:px-12">
      <div class="mb-12" data-reveal="fade-up">
        <p class="section-kicker mb-4">Common Questions</p>
        <h2 class="font-heading text-charcoal" style="font-size: clamp(2rem, 4vw, var(--text-section));">Before you get in touch</h2>
      </div>

      <div class="divide-y divide-charcoal/10" data-reveal="fade-up" data-reveal-delay="2">
        {faqs.map((item) => (
          <details class="group py-6">
            <summary class="flex items-center justify-between gap-4 list-none cursor-pointer">
              <h3 class="font-heading text-lg text-charcoal group-open:text-celtic transition-colors">{item.q}</h3>
              <span class="flex-shrink-0 w-5 h-5 text-brass">
                <svg class="group-open:rotate-45 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
              </span>
            </summary>
            <p class="text-text leading-relaxed mt-4 max-w-2xl">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding bg-charcoal">
    <div class="content-narrow px-6 lg:px-12 text-center">
      <h2 class="font-heading-display text-3xl md:text-4xl text-white mb-6" style="font-weight: 300;">
        Ready to start planning?
      </h2>
      <p class="text-white/60 text-lg mb-10 max-w-xl mx-auto">
        Tell us about your dream golf trip and we'll build a personalised proposal.
      </p>
      <a
        href="/contact"
        class="btn-primary btn-lg btn-primary-inverted"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
